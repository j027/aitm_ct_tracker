DISCORD_WEBHOOK=<discord webhook URL>
DISCORD_WEBHOOK_WATCHED=<discord webhook URL>  # Optional: secondary webhook for orgs listed in watched_org_ids.txt
CERTSTREAM_WS_URL=ws://127.0.0.1:8080/ 
EMAIL_ENABLED=<true or false>                          # Master kill-switch: disables mailto links in Discord alerts AND automated SMTP emails
SMTP_ENABLED=<true or false>
SMTP_HOST=<SMTP server host>
SMTP_PORT=<SMTP server port>
SMTP_USERNAME=<SMTP username>
SMTP_PASSWORD=<SMTP password>
SMTP_FROM_EMAIL=<email address to use in the "From" field of the email>